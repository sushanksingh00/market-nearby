# Copy this file to .env and fill in with your actual values
# For local development:
DB_NAME=market_nearby
DB_USER=market_user
DB_PASSWORD=market@123
DB_HOST=localhost
DB_PORT=5432
DEBUG=False

# For Render deployment, set these environment variables in Render dashboard:
# DB_NAME - PostgreSQL database name
# DB_USER - PostgreSQL username
# DB_PASSWORD - PostgreSQL password
# DB_HOST - PostgreSQL host (provided by Render)
# DB_PORT - PostgreSQL port (usually 5432)
# ALLOWED_HOSTS - Comma-separated list (e.g., yourapp.onrender.com,www.yourapp.onrender.com)
# CSRF_TRUSTED_ORIGINS - Comma-separated list (e.g., https://yourapp.onrender.com,https://www.yourapp.onrender.com)
# DEBUG - Set to False in production
# SECURE_SSL_REDIRECT - Set to True in production
